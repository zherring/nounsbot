# Required for evaluation (backtest + poller)
ANTHROPIC_API_KEY=

# Optional overrides
# ANTHROPIC_MODEL=claude-opus-4-8
# SUBGRAPH_URL=https://www.nouns.camp/subgraphs/nouns
# POLL_INTERVAL_SECONDS=120

# Telegram ratification channel
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# M1 execution (generate with: python -m bot.keygen — vote-only EOA)
# BOT_PRIVATE_KEY=
# RPC_URL=https://ethereum-rpc.publicnode.com
# NOUNS_CLIENT_ID=0

# Railway only: GitHub fine-grained PAT (contents:write) so the loop can
# push verdicts.json to the repo -> Pages redeploys the record
# GIT_PUSH_TOKEN=
